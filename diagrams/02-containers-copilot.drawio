        <mxCell id="c_vscode" value="&lt;b&gt;VS Code + Extensi&#243;n GitHub Copilot&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Container: Electron + TypeScript]&lt;/i&gt;&lt;br&gt;&lt;br&gt;IDE del desarrollador. Soporta autocompletado, Copilot Chat, modo agente y modo plan." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="b_dev">
          <mxGeometry x="40" y="60" width="280" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="c_cli" value="&lt;b&gt;GitHub Copilot CLI&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Container: Node.js]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Cliente Copilot en la terminal del desarrollador con modo agente." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="b_dev">
          <mxGeometry x="370" y="60" width="280" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="c_mcp_local" value="&lt;b&gt;MCPs locales&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Containers: procesos hijos &#183; stdio / JSON-RPC]&lt;/i&gt;&lt;br&gt;&lt;br&gt;P. ej. draw.io MCP (en uso) y otros futuros. Lanzados por VS Code o el CLI; sin egress propio salvo que el MCP lo haga." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="b_dev">
          <mxGeometry x="40" y="240" width="610" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="c_shell" value="&lt;b&gt;Shell / scripts del usuario&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Container: PowerShell / cmd / bash]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Procesos invocados por el modo agente para ejecutar comandos y scripts en la m&#225;quina." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="b_dev">
          <mxGeometry x="40" y="410" width="610" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="c_git" value="&lt;b&gt;Cliente Git&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Container: git.exe]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Clona, hace pull y push contra Azure DevOps Repos." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="b_dev">
          <mxGeometry x="40" y="555" width="610" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="b_saas" value="GitHub Copilot &#8212; SaaS (github.com / Enterprise tuyacol)" style="swimlane;startSize=30;fillColor=none;strokeColor=#444444;fontColor=#444444;fontStyle=1;dashed=1;html=1;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="780" y="180" width="520" height="700" as="geometry"/>
        </mxCell>
        <mxCell id="c_admin_console" value="&lt;b&gt;Consola de administraci&#243;n de Copilot&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Container: Web app &#183; github.com]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Asignaci&#243;n de licencias, pol&#237;ticas y m&#233;tricas del Enterprise &lt;b&gt;tuyacol&lt;/b&gt;." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="b_saas">
          <mxGeometry x="40" y="60" width="440" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="c_proxy" value="&lt;b&gt;Proxy de Copilot&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Container: API HTTPS]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Recibe los prompts de los clientes Copilot, aplica filtros (p. ej. duplicate detection) y enruta al servicio de modelos." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="b_saas">
          <mxGeometry x="40" y="240" width="440" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="c_models" value="&lt;b&gt;Servicio de modelos LLM&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Container: Backend opaco]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Modelos detr&#225;s del proxy de GitHub. Detalle interno fuera de alcance." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="b_saas">
          <mxGeometry x="40" y="440" width="440" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="b_mcp" value="Plataforma corporativa de MCPs (Azure &#183; ambiente dev)" style="swimlane;startSize=30;fillColor=none;strokeColor=#444444;fontColor=#444444;fontStyle=1;dashed=1;html=1;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="1340" y="180" width="820" height="700" as="geometry"/>
        </mxCell>
        <mxCell id="c_apim" value="&lt;b&gt;Azure API Management&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Container: APIM]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Expone p&#250;blicamente el MCP corporativo. Solo enruta tr&#225;fico (sin auth propia)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="b_mcp">
          <mxGeometry x="30" y="60" width="260" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="b_aks" value="AKS &#183; cluster de desarrollo" style="swimlane;startSize=24;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#7F6000;fontStyle=1;html=1;rounded=0;" vertex="1" parent="b_mcp">
          <mxGeometry x="320" y="60" width="470" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="c_pod_sonar" value="&lt;b&gt;Pod: SonarCloud MCP Server&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Container: imagen oficial SonarCloud]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Atiende JSON-RPC del cliente Copilot. Lleva el token administrador de SonarCloud como variable de entorno del deployment." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="b_aks">
          <mxGeometry x="20" y="40" width="430" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="c_ingress" value="&lt;b&gt;Ingress / Service&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Container: Kubernetes ingress]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Expone el pod del MCP hacia APIM." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="b_aks">
          <mxGeometry x="20" y="220" width="430" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="c_acr" value="&lt;b&gt;Azure Container Registry (ACR)&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Container: Registry]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Aloja la imagen del MCP. Origen: copia tra&#237;da inicialmente desde Docker Hub." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#2E6295;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="b_mcp">
          <mxGeometry x="30" y="470" width="260" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="sys_netskope" value="&lt;b&gt;Netskope SWG&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Sistema externo &#183; Secure Web Gateway corporativo]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Aplica pol&#237;ticas y permite la lista de URLs requeridas por Copilot y los MCPs corporativos." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6B6B6B;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="940" width="700" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="sys_entra" value="&lt;b&gt;Microsoft Entra ID&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Sistema externo &#183; IdP]&lt;/i&gt;&lt;br&gt;&lt;br&gt;IdP corporativo. SAML SSO configurado (no obligatorio). Sincroniza el grupo de seguridad para licenciamiento." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6B6B6B;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="780" y="940" width="520" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="sys_sonar" value="&lt;b&gt;SonarCloud&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Sistema externo &#183; SaaS de calidad de c&#243;digo]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Provee m&#233;tricas e issues. Emite tokens de usuario y de administrador." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6B6B6B;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="1340" y="940" width="820" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="sys_ado" value="&lt;b&gt;Azure DevOps Repos&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Sistema externo &#183; Repositorios]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Hospeda el c&#243;digo fuente que el desarrollador edita con Copilot." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6B6B6B;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="1100" width="700" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="legend" value="&lt;b&gt;Leyenda&lt;/b&gt;&#160;&#160;&lt;font color=&quot;#08427B&quot;&gt;&#9632;&lt;/font&gt; Persona&#160;&#160;&lt;font color=&quot;#438DD5&quot;&gt;&#9632;&lt;/font&gt; Contenedor (dentro del sistema en foco)&#160;&#160;&lt;font color=&quot;#999999&quot;&gt;&#9632;&lt;/font&gt; Sistema externo&#160;&#160;&#9647; Boundary (l&#237;nea punteada)" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="780" y="1100" width="1380" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="note" value="&lt;b&gt;Notas:&lt;/b&gt; SSO Entra ID configurado pero no enforced &#183; sin Content Exclusions &#183; audit logs no exportados a SIEM &#183; MCP corporativo solo en ambiente dev &#183; APIM solo enruta (sin auth propia) &#183; token admin de SonarCloud en variable de entorno del deployment." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF4C2;strokeColor=#D6B656;fontColor=#333333;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
          <mxGeometry x="780" y="1160" width="1380" height="60" as="geometry"/>
        </mxCell>

