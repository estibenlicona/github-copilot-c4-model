        <mxCell id="b_dev" value="Estaci&#243;n del desarrollador" style="swimlane;startSize=30;fillColor=none;strokeColor=#444444;fontColor=#444444;fontStyle=1;dashed=1;html=1;rounded=0;" vertex="1" parent="1">
