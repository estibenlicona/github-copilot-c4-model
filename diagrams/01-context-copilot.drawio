        <mxCell id="title" parent="1" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" value="GitHub Copilot — C4 Modelo · Nivel 1: Contexto del Sistema" vertex="1">
          <mxGeometry height="36" width="1620" x="40" y="10" as="geometry" />
        </mxCell>
        <mxCell id="p_admin_cop" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#073B6F;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" value="&lt;b&gt;Administrador de Copilot&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Persona]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Gestiona licencias, políticas y consulta métricas en la consola de admin." vertex="1">
          <mxGeometry height="120" width="220" x="60" y="80" as="geometry" />
        </mxCell>
        <mxCell id="p_dev" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#073B6F;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" value="&lt;b&gt;Desarrollador&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Persona]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Escribe código asistido por Copilot (autocompletado, Chat, modo agente, modo plan) en VS Code y Copilot CLI." vertex="1">
          <mxGeometry height="120" width="220" x="740" y="80" as="geometry" />
        </mxCell>
        <mxCell id="p_admin_sonar" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;strokeColor=#073B6F;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" value="&lt;b&gt;Administrador de SonarCloud&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Persona]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Genera el token administrador y opera el despliegue del MCP en AKS." vertex="1">
          <mxGeometry height="120" width="220" x="1420" y="80" as="geometry" />
        </mxCell>
        <mxCell id="sys_copilot" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#0B4884;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=10;fontStyle=0;" value="&lt;b&gt;GitHub Copilot — uso corporativo&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Sistema en foco · Copilot Business]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Asistencia de código basada en LLM consumida desde VS Code y Copilot CLI: autocompletado, Chat, modo agente y modo plan. Incluye consola de administración del Enterprise &lt;b&gt;tuyacol&lt;/b&gt; y el proxy de Copilot." vertex="1">
          <mxGeometry height="200" width="380" x="660" y="430" as="geometry" />
        </mxCell>
        <mxCell id="sys_entra" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6B6B6B;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" value="&lt;b&gt;Microsoft Entra ID&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Sistema externo · IdP corporativo]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Mantiene el grupo de seguridad sincronizado con Copilot para licenciamiento. Provee SAML SSO (configurado, no obligatorio)." vertex="1">
          <mxGeometry height="160" width="240" x="60" y="450" as="geometry" />
        </mxCell>
        <mxCell id="sys_ado" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6B6B6B;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" value="&lt;b&gt;Azure DevOps Repos&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Sistema externo · Repositorios]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Hospeda el código fuente que los desarrolladores editan localmente con Copilot." vertex="1">
          <mxGeometry height="160" width="240" x="1400" y="450" as="geometry" />
        </mxCell>
        <mxCell id="sys_netskope" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6B6B6B;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" value="&lt;b&gt;Netskope&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Sistema externo · SWG corporativo]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Aplica políticas de navegación y permite el grupo de URLs requeridas por Copilot y MCPs corporativos." vertex="1">
          <mxGeometry height="160" width="240" x="60" y="780" as="geometry" />
        </mxCell>
        <mxCell id="sys_llm" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6B6B6B;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" value="&lt;b&gt;Servicio de modelos LLM de Copilot&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Sistema externo · Backend opaco]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Recibe prompts y devuelve completions a través del proxy oficial de GitHub Copilot." vertex="1">
          <mxGeometry height="160" width="260" x="720" y="780" as="geometry" />
        </mxCell>
        <mxCell id="sys_mcp_platform" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6B6B6B;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" value="&lt;b&gt;Plataforma corporativa de MCPs&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Sistema externo interno · APIM + AKS dev + ACR]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Expone MCP servers corporativos. Hoy aloja el SonarCloud MCP (imagen oficial · ambiente de desarrollo) detrás de Azure API Management. Token admin de SonarCloud cargado como variable de entorno del deployment." vertex="1">
          <mxGeometry height="180" width="280" x="1140" y="780" as="geometry" />
        </mxCell>
        <mxCell id="sys_sonar" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#6B6B6B;fontColor=#FFFFFF;align=center;verticalAlign=top;spacingTop=8;" value="&lt;b&gt;SonarCloud&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Sistema externo · SaaS de calidad de código]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Provee métricas e issues de los proyectos. Emite tokens de usuario y de administrador." vertex="1">
          <mxGeometry height="140" width="240" x="1440" y="990" as="geometry" />
        </mxCell>
        <mxCell id="note_local_mcp" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF4C2;strokeColor=#D6B656;fontColor=#333333;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;Nota:&lt;/b&gt; los MCPs &lt;u&gt;locales&lt;/u&gt; (p. ej. draw.io, futuros) corren en la máquina del desarrollador como procesos hijos del cliente Copilot (stdio). No salen a la red salvo que el propio MCP lo haga." vertex="1">
          <mxGeometry height="80" width="380" x="340" y="240" as="geometry" />
        </mxCell>
        <mxCell id="note_governance" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF4C2;strokeColor=#D6B656;fontColor=#333333;align=left;verticalAlign=top;spacingLeft=10;spacingRight=10;spacingTop=8;" value="&lt;b&gt;Notas de gobierno:&lt;/b&gt;&lt;br&gt;• SSO con Entra ID configurado pero &lt;b&gt;no obligatorio&lt;/b&gt;.&lt;br&gt;• Sin Content Exclusions configuradas.&lt;br&gt;• Audit logs no exportados a SIEM.&lt;br&gt;• Gobierno de IA en definición." vertex="1">
          <mxGeometry height="120" width="280" x="40" y="240" as="geometry" />
