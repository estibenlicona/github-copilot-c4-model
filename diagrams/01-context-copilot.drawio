<mxfile host="Electron" agent="Copilot CLI">
  <diagram id="c1-context-copilot" name="C1 - Contexto">
    <mxGraphModel dx="1347" dy="801" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0" adaptiveColors="auto">
      <root>
        <mxCell id="0" />
