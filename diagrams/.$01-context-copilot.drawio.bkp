          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_entra_cop" edge="1" parent="1" source="sys_entra" target="sys_copilot" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;" value="Sincroniza grupo de seguridad para licenciamiento&#10;[SCIM] &#183; SAML SSO disponible (no enforced)">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
