          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_netskope_llm" edge="1" parent="1" source="sys_netskope" target="sys_llm" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;" value="Tr&#225;fico permitido hacia el proxy de Copilot&#10;[HTTPS]">
          <mxGeometry relative="1" as="geometry"/>
