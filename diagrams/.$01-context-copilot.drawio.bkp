        <mxCell id="e_cop_mcp" edge="1" parent="1" source="sys_copilot" target="sys_mcp_platform" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;dashed=0;" value="Consume MCP corporativo (SonarCloud)&#10;[HTTPS &#183; APIM &#183; token de usuario]">
          <mxGeometry relative="1" as="geometry"/>
