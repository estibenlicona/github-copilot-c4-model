          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_admin_sonar_sonar" edge="1" parent="1" source="p_admin_sonar" target="sys_sonar" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;" value="Genera tokens (admin / usuario)&#10;[HTTPS]">
